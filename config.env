# Configuration globale du repo
BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

GITHUB_RUNNER_DIR="$BASE_DIR/scripts/github-runner"
API_DIR="$BASE_DIR/scripts/api"
DB_DIR="$BASE_DIR/scripts/db"
CRONS_DIR="$BASE_DIR/crons"
SCRIPTS_DIR="$BASE_DIR/scripts"

EXTERNAL_BASE_DIR="$(cd "$BASE_DIR/.." && pwd)"
EXTERNAL_GITHUB_RUNNER_DIR="$EXTERNAL_BASE_DIR/github-runner"
EXTERNAL_CRONS_DIR="$EXTERNAL_BASE_DIR/crons"
EXETERNAL_LOGS_DIR="$EXTERNAL_BASE_DIR/logs"